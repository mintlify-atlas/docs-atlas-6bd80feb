  "keyFeatures": [
    "Random Forest classifier for isoform functional prediction",
    "SHAP-based model interpretability and feature importance",
    "QSplice module for RNA-seq splice junction quantification",
    "Pfam effects analysis for domain-level impact assessment",
    "Support for multiple genome assemblies and species",
    "Pre-computed predictions for GENCODE, RefSeq, and Ensembl annotations"
  ],
  "publicApiSurface": [
    "trifid.models.train - Train TRIFID model with custom or pretrained configurations",
    "trifid.models.predict - Generate functional predictions for splice isoforms",
    "trifid.models.interpret - SHAP-based interpretation of model predictions",
    "trifid.preprocessing.qsplice - Quantify splice junction coverage from RNA-seq",
    "trifid.preprocessing.pfam_effects - Analyze Pfam domain effects of alternative splicing",
    "trifid.preprocessing.label_fragments - Label fragment and duplication isoforms",
    "trifid.data.make_dataset - Create complete feature dataset for training"
  ]
